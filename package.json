{
  "name": "my9",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "dev:test": "node -e \"require('fs').rmSync('.next', { recursive: true, force: true })\" && next dev -H 0.0.0.0",
    "share-count:snapshot": "node scripts/write-share-count-snapshot.mjs",
    "prebuild": "npm run share-count:snapshot",
    "build": "next build",
    "start": "next start",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "npm run cf:build && wrangler dev",
    "cf:deploy": "npm run cf:build && opennextjs-cloudflare deploy",
    "lint": "eslint .",
    "test:e2e": "node node_modules/@playwright/test/cli.js test"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.928.0",
    "@dnd-kit/dom": "^0.3.2",
    "@dnd-kit/helpers": "^0.3.2",
    "@dnd-kit/react": "^0.3.2",
    "@neondatabase/serverless": "^1.0.2",
    "@opennextjs/cloudflare": "1.17.1",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-slot": "^1.1.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.477.0",
    "next": "16.1.6",
    "qrcode": "^1.5.4",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0",
    "simple-icons": "^16.11.0",
    "tailwind-merge": "^3.0.2",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.0",
    "@types/node": "^20",
    "@types/qrcode": "^1.5.6",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.1.6",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "typescript": "^5",
    "wrangler": "4.73.0"
  }
}
